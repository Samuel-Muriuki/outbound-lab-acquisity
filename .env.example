# ============================================
# OUTBOUNDLAB ENVIRONMENT VARIABLES (FREE-TIER)
# ============================================
# Copy to .env.local and fill in real values.
# NEVER commit .env.local — secrets only.
# All providers below are FREE TIERS — no payment method required.
#
# Phase markers:
#   [P1] required for Phase 1 (MVP)
#   [P2] required for Phase 2 (caching + Vercel AI SDK)
#   [P3] optional Phase 3 add-ons (rate limit, monitoring)
#
# Why no OPENAI_API_KEY?  We use the `openai` npm SDK as the transport for
# Groq and OpenRouter (both speak OpenAI-compatible API), but never call
# OpenAI's models directly. Embeddings are Gemini text-embedding-004 (768d).

# ============================================
# DATABASE — Supabase                                              [P1]
# ============================================
# Free tier, Singapore region. https://supabase.com
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Dashboard → Project Settings → API → service_role (KEEP SECRET — server only)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional: direct Postgres URL for migrations + Drizzle
DATABASE_URL=postgresql://postgres.PROJECT-REF:PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# ============================================
# LLM PROVIDER CHAIN — Groq → Gemini → OpenRouter                  [P1]
# ============================================
# Order is locked in src/lib/agents/llm/chat.ts. Provider chain is part of
# the demo's value proposition — do not reorder.
#
# At least ONE key must be set; all three is recommended for resilience.
# In Phase 2, GEMINI_API_KEY is REQUIRED (also powers text-embedding-004).

# 1. PRIMARY: Groq — fastest inference (~500 tok/s for Llama 3.3 70B)
#    Sign up:    https://console.groq.com
#    Free tier:  14,400 req/day · 30 req/min · 6,000 tokens/min
GROQ_API_KEY=gsk_your_groq_key_here

# 2. FALLBACK: Google Gemini 2.5 Flash + text-embedding-004
#    Sign up:    https://aistudio.google.com/app/apikey
#    Free tier:  1,500 req/day for gemini-2.5-flash; embeddings unlimited
GEMINI_API_KEY=AIza_your_gemini_key_here

# 3. LAST RESORT: OpenRouter — routes to free Llama hosts when Groq + Gemini are down
#    Sign up:    https://openrouter.ai
#    Free tier:  ~50 req/day on free models (varies)
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here

# ============================================
# SEARCH TOOL — Tavily                                             [P1]
# ============================================
# Built for LLM agents — returns clean markdown.
# Sign up:    https://tavily.com
# Free tier:  1,000 searches / month
TAVILY_API_KEY=tvly-your-tavily-key-here

# ============================================
# RATE LIMITING — Upstash Redis (optional)                         [P3]
# ============================================
# https://console.upstash.com (free 10K commands/day)
# Phase 1-2 use the Postgres rate_limits table by default; uncomment to
# switch to Upstash Redis when traffic justifies it.
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ============================================
# MONITORING — Sentry (optional)                                   [P3]
# ============================================
# https://sentry.io (free 5K errors/month)
# NEXT_PUBLIC_SENTRY_DSN=https://your-key@o000000.ingest.sentry.io/0000000
# SENTRY_AUTH_TOKEN=sntrys_your_auth_token

# ============================================
# APP CONFIGURATION                                                [P1]
# ============================================
# In production, set this to the actual deployed URL. Used as
# OpenRouter's HTTP-Referer attribution and as canonical URLs in OG tags.
NEXT_PUBLIC_APP_URL=https://outbound-lab.vercel.app
NODE_ENV=development

# ============================================
# RUNTIME CAPS — safety rails                                      [P3]
# ============================================
# Daily research-run limit per IP. Wired to the rate_limits table once
# Phase 3 lands; safe to leave at 10 from day 1.
MAX_RUNS_PER_IP_PER_DAY=10
